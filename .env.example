# Ollama — per-agent model config
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_ORCHESTRATOR=mistral
OLLAMA_MODEL_CODING=codellama
OLLAMA_MODEL_RESEARCH=mistral

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# Neo4j (host ports 7475/7688 — internal bolt always on neo4j:7687)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Agent-to-agent routing (internal Docker network URLs)
CODING_AGENT_URL=http://coding_agent:8000
RESEARCH_AGENT_URL=http://research_agent:8000
GRAPH_WORKER_URL=http://graph_worker:8000

# Orchestrator
API_CORS_ORIGINS=http://localhost:3010
LOG_LEVEL=INFO

# Frontend (baked in at build time)
VITE_API_URL=http://localhost:8040

# Optional: GitHub personal access token (raises API rate limit from 60 to 5000 req/hr)
# GITHUB_TOKEN=ghp_...
